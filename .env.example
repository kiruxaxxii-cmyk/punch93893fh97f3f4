# Railway / production env (set once, then remove RESET_AND_SEED_ADMIN)
#
# RESET_AND_SEED_ADMIN=1   — wipe all users and create single admin (one deploy only)
# ADMIN_USERNAME=punchadmin
# ADMIN_EMAIL=admin@punch.local
# ADMIN_PASSWORD=your_secure_password
# JWT_SECRET=random_long_string
#
# CryptoBot / Crypto Pay (@send / @CryptoBot)
# Токен: Crypto Bot → Crypto Pay → My Apps → API Token
# Webhook URL: https://YOUR-DOMAIN/api/payments/cryptobot/webhook
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_START=IVmm6S9JZYCJ
# SITE_URL=http://localhost:3001
# PUNCH_DB_PATH=data/punch-ebd.db
# PUNCH_SEED_DB=1  — copy bundled data/punch-ebd.db into runtime DB on deploy (one-time)
